datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Generic naming per ADR 0010 — no domovina-specific entity names.
// `User` owns one or more `Passkey` credentials; each `Passkey` binds
// to a single Safe smart-contract wallet address on the configured chain
// (see brand.config.ts coming in Phase 2).
//
// Phase 1 (auth) populates User + Passkey.
// Phase 2 (wallet) adds Wallet, PaymentIntent, PeerLink models.

model User {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  passkeys  Passkey[]
}

model Passkey {
  id           String   @id @default(uuid())
  credentialId String   @unique
  pubkey       String
  safeAddr     String
  signCount    Int      @default(0)
  createdAt    DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  userId String
}

// Short-lived WebAuthn challenges issued by passkeyRegisterStart /
// passkeyAuthStart and consumed (deleted) by their *Finish counterparts.
// Cleared after 5 minutes if unused.
model WebAuthnChallenge {
  id        String   @id @default(uuid())
  challenge String   @unique
  purpose   String   // "register" | "auth"
  createdAt DateTime @default(now())
  expiresAt DateTime
}
