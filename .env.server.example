# JWT secret for signing session tokens. CHANGE THIS for non-dev deployments.
# Generate with: openssl rand -hex 32
JWT_SECRET=dev-only-replace-with-openssl-rand-hex-32

# Relayer EOA private key for sponsoring gas on the configured chain.
# Required for /send to broadcast real transactions; otherwise the
# sendEure action returns a stub txHash and tests still pass.
# Format: 0x-prefixed 64 hex chars.
# RELAYER_PRIVATE_KEY=0x...

# WebAuthn Relying Party identifiers (optional — defaults derived from
# WASP_WEB_CLIENT_URL). Override for production deploys where RP ID
# must match the actual deployment domain.
# WASP_WEB_RP_ID=wallet.example.com
# WASP_WEB_RP_NAME=Example Wallet

# Optional port override if 3000/3001 are taken on your machine.
# PORT=4001
# WASP_WEB_CLIENT_URL=http://localhost:4000
